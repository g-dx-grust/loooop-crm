# --- Database ---
# Local: postgres://postgres:postgres@localhost:5432/looop_crm
# Neon:  postgres://...@...neon.tech/looop_crm?sslmode=require
DATABASE_URL=

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Consent ---
CONSENT_TEXT_VERSION=v1.0

# --- PII pepper (for phone_hash) ---
# 必ず本番ではランダムな長い文字列に置き換える
PII_PEPPER=dev-only-pepper-change-me

# --- Stub auth (Phase 0 のみ) ---
# 仮ユーザの role を切り替える: admin | manager | field | cs | finance
STUB_AUTH_ROLE=admin
STUB_AUTH_USER_NAME=開発太郎

# --- Google Maps（未取得なら空でOK、地図機能はスタブで動作）---
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
GOOGLE_MAPS_SERVER_KEY=

# --- Vercel Blob (未取得なら空でOK、写真アップロードはスタブで動作) ---
BLOB_READ_WRITE_TOKEN=
