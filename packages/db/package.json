{
  "name": "@looop/db",
  "version": "0.0.0",
  "private": true,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "generate": "drizzle-kit generate",
    "migrate": "tsx src/migrate.ts",
    "studio": "drizzle-kit studio",
    "typecheck": "tsc --noEmit",
    "seed": "tsx src/run-seed.ts",
    "db:reset": "rm -f ../../.local-db/looop.db ../../.local-db/looop.db-shm ../../.local-db/looop.db-wal && tsx src/run-seed.ts"
  },
  "dependencies": {
    "better-sqlite3": "^12.9.0",
    "drizzle-orm": "0.36.4",
    "pg": "8.13.1",
    "postgres": "3.4.5"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "22.10.5",
    "@types/pg": "8.11.10",
    "drizzle-kit": "0.28.1",
    "tsx": "4.19.2",
    "typescript": "5.6.3"
  }
}
